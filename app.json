{
  "expo": {
    "name": "franchise.v2",
    "slug": "franchise-v2",
    "version": "1.1.6",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "franchisev2",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.chewers.franchisev2",
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "LSApplicationQueriesSchemes": ["venmo", "cashapp", "paypal"],
        "NSCameraUsageDescription": "Franchise uses the camera to take photos for chat messages and team logos.",
        "NSPhotoLibraryUsageDescription": "Franchise uses your photo library to share images in chat and set team logos."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#E9E2CB"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.chewers.franchisev2"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/patch_logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#1B3D2F"
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-font",
      [
        "expo-image-picker",
        {
          "cameraPermission": "Franchise uses the camera to take photos for chat messages and team logos.",
          "photosPermission": "Franchise uses your photo library to share images in chat and set team logos."
        }
      ],
      "expo-web-browser",
      "expo-apple-authentication",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#ffffff",
          "sounds": []
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.352302197811-pt3tu6ohuktd738g1gtk81jsrqmk7p14"
        }
      ],
      ["@sentry/react-native/expo", { "uploadSourceMaps": false }]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "bc023770-8f00-49df-9fa0-0afdd24f6a44"
      }
    },
    "runtimeVersion": {
      "policy": "fingerprint"
    },
    "updates": {
      "url": "https://u.expo.dev/bc023770-8f00-49df-9fa0-0afdd24f6a44"
    }
  }
}
